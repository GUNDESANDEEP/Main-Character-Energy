{
  "info": {
    "name": "Notes App Backend",
    "description": "Collection for testing Notes App API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"securePassword123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5002/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set(\"token\", jsonData.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"securePassword123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5002/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set(\"token\", jsonData.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5002/api/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Notes",
      "item": [
        {
          "name": "Get All Notes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5002/api/notes",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "notes"]
            }
          }
        },
        {
          "name": "Create Note",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Note\",\n  \"content\": \"This is the content of my note\",\n  \"category\": \"personal\",\n  \"color\": \"#FFE082\",\n  \"tags\": [\"important\", \"reminder\"]\n}"
            },
            "url": {
              "raw": "http://localhost:5002/api/notes",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "notes"]
            }
          }
        },
        {
          "name": "Get Note by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5002/api/notes/NOTE_ID",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "notes", "NOTE_ID"]
            }
          }
        },
        {
          "name": "Update Note",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Note Title\",\n  \"content\": \"Updated content here\",\n  \"isPinned\": true,\n  \"category\": \"work\"\n}"
            },
            "url": {
              "raw": "http://localhost:5002/api/notes/NOTE_ID",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "notes", "NOTE_ID"]
            }
          }
        },
        {
          "name": "Delete Note",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5002/api/notes/NOTE_ID",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "notes", "NOTE_ID"]
            }
          }
        },
        {
          "name": "Get Notes by Category",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5002/api/notes/category/work",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "notes", "category", "work"]
            }
          }
        },
        {
          "name": "Search Notes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5002/api/notes/search?query=meeting",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "notes", "search"],
              "query": [
                {
                  "key": "query",
                  "value": "meeting"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
